# OpenAI
# - 커스텀 시나리오 생성: gpt-4o-mini
# - 얼굴 합성 테스트 (/admin/face-test): gpt-image-1 (이미지 편집)
OPENAI_API_KEY=sk-xxxxxxxxxxxx

# Gemini Nano Banana 2 (배경/캐릭터 이미지 생성)
# 모델: gemini-3.1-flash-image-preview
GEMINI_API_KEY=AIzaxxxxx

# Replicate (face-swap fallback 전용)
# 배경/캐릭터는 Gemini를 사용하고, 실제 아이 얼굴 합성만 Replicate의
# codeplugtech/face-swap 모델로 수행한다
REPLICATE_API_TOKEN=r8_xxxxxxxxxxxx

# true로 설정하면 AI 호출 없이 placeholder 이미지 반환 (비용 0)
# GEMINI_API_KEY 또는 REPLICATE_API_TOKEN이 없어도 자동으로 mock 모드 진입
USE_MOCK_AI=false
# 실제 AI 생성할 페이지 수 제한 (미설정 시 전체 12장 생성)
# 예: 3 → 처음 3장만 실제 생성, 나머지 placeholder
# DEV_PAGE_LIMIT=3

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxx

# 토스페이먼츠
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_xxxx
TOSS_SECRET_KEY=test_sk_xxxx

# 앱
NEXT_PUBLIC_BASE_URL=http://localhost:3000
